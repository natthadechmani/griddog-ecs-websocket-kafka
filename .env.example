# Local dev defaults. Copy to .env: `cp .env.example .env`
# docker-compose already sets the in-container values; these are for running
# the seed script (and any service) directly on the host.

# Used by scripts/seed.js when run on the host (mongo port is published by compose)
MONGO_URI=mongodb://localhost:27017/griddog

# Service ports (defaults baked into each service; override if needed)
# STORE_API_PORT=4000
# CMS_API_PORT=4001
# STOREFRONT_PORT=3000
# CMS_UI_PORT=3001
